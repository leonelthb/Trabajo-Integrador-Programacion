<?xml version="1.0" encoding="UTF-8"?>

<!-- archivo principal de configuración JPA -->
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"

             xsi:schemaLocation="
             https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"

             version="3.0">

    <!-- unidad de persistencia -->
    <persistence-unit name="miUnidad"
                      transaction-type="RESOURCE_LOCAL">



        <!-- proveedor JPA -->
        <provider>
            org.hibernate.jpa.HibernatePersistenceProvider
        </provider>

        <!-- Clases -->
        <class>com.tu.programacion3.entities.Producto</class>
        <class>com.tu.programacion3.entities.Categoria</class>
        <class>com.tu.programacion3.entities.Usuario</class>
        <class>com.tu.programacion3.entities.Pedido</class>
        <class>com.tu.programacion3.entities.DetallePedido</class>

        <!-- ========================= -->
        <!-- CONFIGURACION BASE DATOS -->
        <!-- ========================= -->

        <properties>

            <!-- driver de H2 -->
            <property
                    name="jakarta.persistence.jdbc.driver"
                    value="org.h2.Driver"/>

            <!-- ubicación de la base -->
            <property
                    name="jakarta.persistence.jdbc.url"
                    value="jdbc:h2:file:./data/jpa_db"/>

            <!-- usuario -->
            <property
                    name="jakarta.persistence.jdbc.user"
                    value="sa"/>

            <!-- password -->
            <property
                    name="jakarta.persistence.jdbc.password"
                    value=""/>

            <!-- dialecto hibernate -->
            <property
                    name="hibernate.dialect"
                    value="org.hibernate.dialect.H2Dialect"/>

            <!-- crear/actualizar tablas automáticamente -->
            <property
                    name="hibernate.hbm2ddl.auto"
                    value="update"/>

            <!-- mostrar SQL en consola -->
            <property
                    name="hibernate.show_sql"
                    value="false"/>

            <!-- formatear SQL -->
            <property
                    name="hibernate.format_sql"
                    value="false"/>

        </properties>

    </persistence-unit>

</persistence>